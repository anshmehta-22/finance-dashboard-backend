// Rate limit settings are enforced in middleware and can be adjusted per environment.
PORT=3000
NODE_ENV=development
# Use at least 32 random bytes (64 hex chars). Example command: openssl rand -hex 32
JWT_SECRET=replace_with_a_64_char_hex_jwt_secret
# PostgreSQL connection string (required for local dev and production).
# Local example: postgresql://user:password@localhost:5432/finance_dashboard
# Production example: postgresql://user:password@db-host:5432/finance_dashboard?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/finance_dashboard"
# Required when running `npm run seed`. Use strong unique values per role.
SEED_ADMIN_PASSWORD=replace_with_a_strong_admin_password
SEED_ANALYST_PASSWORD=replace_with_a_strong_analyst_password
SEED_VIEWER_PASSWORD=replace_with_a_strong_viewer_password
